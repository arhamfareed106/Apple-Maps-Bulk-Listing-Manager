# Apple Business Connect API Configuration
APPLE_CLIENT_ID=your_apple_client_id
APPLE_CLIENT_SECRET=your_apple_client_secret
APPLE_TEAM_ID=your_apple_team_id
APPLE_KEY_ID=your_apple_key_id
APPLE_PRIVATE_KEY_PATH=path/to/your/private/key.p8

# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/apple_maps_db
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Aggregator API Keys
YEXT_API_KEY=your_yext_api_key
YEXT_ACCOUNT_ID=your_yext_account_id

UBERALL_API_KEY=your_uberall_api_key
UBERALL_ACCOUNT_ID=your_uberall_account_id

RIO_SEO_API_KEY=your_rio_seo_api_key
RIO_SEO_ACCOUNT_ID=your_rio_seo_account_id

# Application Settings
LOG_LEVEL=INFO
LOG_FILE=data/logs/app.log
MAX_CONCURRENT_REQUESTS=10
BATCH_SIZE=100
RETRY_MAX_ATTEMPTS=3
RETRY_BACKOFF_FACTOR=2

# Email/Slack Notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
NOTIFICATION_EMAIL=your_email@gmail.com

SLACK_WEBHOOK_URL=your_slack_webhook_url

# Development Settings
DEBUG=False
TESTING=False